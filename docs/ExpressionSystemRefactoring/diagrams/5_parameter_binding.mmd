graph TB
    subgraph "1. Node Creation"
        NC["expression_type + logic_type
        BOUND TOGETHER
        Example: BooleanLogicalAndNode"]
    end
    
    subgraph "2. System Creation"  
        SC["backend_type
        BOUND TO SYSTEM
        Example: PolarsExpressionSystem"]
    end
    
    subgraph "3. Visitor Creation"
        VC["backend_type inherited
        VISITOR IS LOGIC-AGNOSTIC
        Example: UniversalVisitor(polars_system)"]
    end
    
    subgraph "4. Method Dispatch"
        MD["expression_type + logic_type
        DETERMINE METHOD
        Example: visit_boolean_logical_and()"]
    end
    
    subgraph "5. Parameter Processing"
        PP["backend_type + optional visitor
        FOR CONVERSION
        Example: ExpressionParameter(polars_system, visitor)"]
    end
    
    NC --> MD
    SC --> VC
    VC --> PP
    MD --> PP