graph LR
    subgraph "ExpressionNode"
        EN["ExpressionNode
        BINDS: expression_type + logic_type"]
        EN --> EN1["BooleanLogicalAndNode
        expression_type=logical_and
        logic_type=boolean"]
        EN --> EN2["TernaryLogicalAndNode
        expression_type=logical_and
        logic_type=ternary"]
        EN --> EN3["BooleanComparisonGtNode
        expression_type=comparison_gt
        logic_type=boolean"]
        EN --> EN4["TernaryComparisonGtNode
        expression_type=comparison_gt
        logic_type=ternary"]
    end
    
    subgraph "Visitor"
        V["UniversalVisitor
        BINDS: backend_type only"]
        V --> V1["UniversalVisitor
        (NarwhalsExpressionSystem)"]
        V --> V2["UniversalVisitor
        (PolarsExpressionSystem)"]
        V --> V3["UniversalVisitor
        (IbisExpressionSystem)"]
    end
    
    subgraph "VisitorMethods"
        VM["Visitor Methods
        BINDS: expression_type + logic_type"]
        VM --> VM1["visit_boolean_logical_and
        handles: logical_and + boolean"]
        VM --> VM2["visit_ternary_logical_and
        handles: logical_and + ternary"]
        VM --> VM3["visit_boolean_comparison_gt
        handles: comparison_gt + boolean"]
        VM --> VM4["visit_ternary_comparison_gt
        handles: comparison_gt + ternary"]
    end
    
    subgraph "ExpressionSystem"
        ES["ExpressionSystem
        BINDS: backend_type only"]
        ES --> ES1["NarwhalsExpressionSystem
        provides all logic operations"]
        ES --> ES2["PolarsExpressionSystem
        provides all logic operations"]
        ES --> ES3["IbisExpressionSystem
        provides all logic operations"]
    end
    
    EN1 -.-> VM1
    EN2 -.-> VM2
    EN3 -.-> VM3
    EN4 -.-> VM4
    
    V1 --> ES1
    V2 --> ES2
    V3 --> ES3